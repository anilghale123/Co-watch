# .env.local.example — copy to .env.local and fill in.
#
# This file is for LOCAL development only. On Railway you do NOT need to set
# any of these — Railway injects PORT and NODE_ENV, and the client connects
# same-origin (leave NEXT_PUBLIC_SOCKET_URL unset). See README "Deploying to
# Railway". For local dev the defaults below also work as-is.

# ---- Client-exposed (must be prefixed NEXT_PUBLIC_) ----
# Origin the browser uses to open the Socket.IO connection.
# Leave blank for same-origin (recommended for local dev).
NEXT_PUBLIC_SOCKET_URL=

# ---- Server-only (NEVER prefixed NEXT_PUBLIC_) ----
# Port the custom Node server (server.js) binds to.
PORT=3000

# Optional TURN server for the ~10-15% of NATs that STUN cannot traverse.
# Required in production; safe to leave blank for same-network local testing.
# SERVER-ONLY — do not expose the credential to the client build.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
